  {
    "index": 0,
    "code": "DWwNtKKoCm9",
    "owner": "@vegan_high_protein",
    "tags": [
      "main",
      "vegan",
      "vegetarian",
      "quick"
    ],
    "title": "Crispy Chili Peanut Udon One-Pot",
    "ingredients": [
      "400g Udon",
      "100g Brokkoli",
      "200g Tempeh (gebraten)",
      "150g Wok-Gemuese",
      "160g veganes Chicken (gebraten)",
      "30g Spinat",
      "60g Erdnussbutterpulver",
      "75ml Wasser",
      "2 EL Sojasauce",
      "2 EL Ahornsirup",
      "1 EL Crispy Chili Oel",
      "Saft 1/2 Limette",
      "250ml light Kokosmilch",
      "200ml Wasser",
      "2 EL Sojasauce",
      "1 TL Currypaste"
    ],
    "preparation": [
      "Alle Zutaten fuer die Erdnusssosse vermischen und zur Seite stellen.",
      "Alle weiteren Zutaten in eine Pfanne geben, mit Deckel ca. 5-7 Min koecheln bis Brokkoli gar ist.",
      "Geniessen."
    ]
  },
  {
    "index": 1,
    "code": "DWd0DWJjLCj",
    "owner": "@ichmachpizza",
    "tags": [
      "bread",
      "vegan",
      "vegetarian"
    ],
    "title": "Bärlauch-Dinkelweckerl",
    "ingredients": [
      "200g Dinkelmehl",
      "100g Dinkelvollkornmehl",
      "6g Salz",
      "3g frische Hefe (oder 1,2g Trockenhehe)",
      "230ml Wasser",
      "50g Bärlauch (geschnitten)"
    ],
    "preparation": [
      "Alles in eine Schüssel geben und vermengen bis das Mehl gebunden ist.",
      "Teig in geölten Behälter geben, abdecken, 16-24h im Kühlschrank.",
      "Teig kalt verarbeiten: Portionen mit Löffel aufs Backblech geben.",
      "Bei 230 Grad mit Dampf ca. 20 Min backen bis goldbraun.",
      "Auskühlen und frisch genießen."
    ]
  },
  {
    "index": 2,
    "code": "DVttwLdjQrM",
    "owner": "@grownourished",
    "tags": [
      "main",
      "vegan",
      "vegetarian",
      "quick"
    ],
    "title": "Crispy Tofu Nuggets",
    "ingredients": [
      "400g Tofu",
      "2 EL Sojasauce",
      "1 TL Knoblauchpulver",
      "1 TL Zwiebelpulver",
      "1 TL Paprikapulver",
      "1 EL Rapsöl (geschmacksneutral)",
      "2 EL Speisestärke",
      "Salz und Pfeffer"
    ],
    "preparation": [
      "Den Tofu in gesalzenem Wasser 5 Min kochen und abkühlen lassen.",
      "Mit Sojasoße, Gewürzen, Rapsöl und Speisestärke vermischen.",
      "Bei 180 Grad im Airfryer ca. 15 Min backen."
    ]
  },
